---
/**
 * <SourceRef> — the canonical "where does this come from" metadata strip.
 * Drop at the very top of an MDX entry, above the content.
 * Replaces the old `> **Source:** ...` blockquote pattern.
 *
 * Usage:
 *   import SourceRef from '../../../components/SourceRef.astro';
 *   <SourceRef repo="atrium" path="backend/lib/projectRegistry.js" commit="9f24423" category="Pattern" />
 */

interface Props {
  /** GitHub repo (user/name). Defaults to the RogerSquare org */
  repo?: string;
  /** Path inside the repo */
  path?: string;
  /** Optional commit SHA (short or long) */
  commit?: string;
  /** Human-readable category (e.g. "Pattern — deployment") */
  category?: string;
  /** Override to a fully-qualified URL if the thing isn't in a known repo */
  href?: string;
  /** Override the display label when href is used */
  label?: string;
}

const { repo, path, commit, category, href, label } = Astro.props;

const finalHref = href
  ? href
  : repo && path
    ? `https://github.com/RogerSquare/${repo}/blob/main/${path}${commit ? `#L1` : ''}`
    : undefined;

const finalLabel = label
  ? label
  : repo && path
    ? `${repo}/${path}`
    : href;
---

<aside class="source-ref" aria-label="Source reference">
  <span class="icon" aria-hidden="true">
    {/* mini GitHub mark */}
    <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor">
      <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
    </svg>
  </span>
  {finalHref ? (
    <a href={finalHref} class="path" target="_blank" rel="noopener">
      <span>{finalLabel}</span>
    </a>
  ) : (
    <span class="path"><span>{finalLabel}</span></span>
  )}
  {commit && (
    <code class="commit" title={`Commit ${commit}`}>{commit.slice(0, 7)}</code>
  )}
  {category && <span class="sep" aria-hidden="true">·</span>}
  {category && <span class="category">{category}</span>}
</aside>

<style>
  .source-ref {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.85rem;
    margin-bottom: 1.75rem;
    background: var(--brand-accent-bg-tint);
    border: 1px solid var(--brand-accent-subtle);
    border-left: 3px solid var(--brand-accent);
    border-radius: 6px;
    font-family: 'DM Mono', ui-monospace, Menlo, monospace;
    font-size: 0.78rem;
    line-height: 1.4;
    color: var(--sl-color-gray-3);
  }
  .icon {
    display: inline-flex;
    color: var(--sl-color-gray-4);
  }
  .path {
    color: var(--sl-color-gray-2);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color 0.15s, border-color 0.15s;
  }
  a.path:hover {
    color: var(--brand-accent);
    border-bottom-color: var(--brand-accent);
  }
  .commit {
    font-size: 0.82em;
    padding: 0.08em 0.35em;
    background: rgba(253, 179, 42, 0.15);
    color: var(--brand-accent);
    border-radius: 3px;
    font-weight: 500;
    font-family: inherit;
  }
  .sep {
    color: var(--sl-color-gray-5);
  }
  .category {
    color: var(--sl-color-gray-4);
  }
</style>
